# Get a personal key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-key-here

# Optional — defaults to gpt-5.5 (latest). Use gpt-5.4-mini for cheaper.
# OPENAI_MODEL=gpt-5.5

# Optional for GPT-5.x — none | low | medium | high (default: low for short tweets)
# OPENAI_REASONING_EFFORT=low

# Monthly spend cap in USD (0 = no limit). Resets each calendar month.
OPENAI_SPEND_CAP_USD=100

# Public URL used for Share links (so localhost still copies the live link)
PUBLIC_APP_URL=https://debates-uvpv.onrender.com
